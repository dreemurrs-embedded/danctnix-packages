pkgrel=1
arch=('any')
url="https://danctnix.org"
license=('GPL')
pkgdesc='Settings files for Plasma Desktop'
depends=(
  'breeze-gtk'
  'kwin'
  'layer-shell-qt'
  'noto-fonts'
  'plasma-desktop'
  'plasma-keyboard'
)
makedepends=('git')
install=$pkgname.install
source=('kwinrc')
sha256sums=('f10f92db7a29eb16165c69f13d417a7bf3dfc2180e7eec3bab056a8a4c215976')

pkgver() {
    date +%Y%m%d
}

package() {
    xdg=$pkgdir/etc/xdg
    install -Dm644 kwinrc $xdg/kwinrc
}
